generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Unidad {
  GRAMO
  KILOGRAMO
  LIBRA
  MILILITRO
  LITRO
  UNIDAD
  PORCION
  CAJA
  BULTO
  GARRAFA
}

enum CategoriaProveedor {
  CARNES
  LACTEOS
  VERDURAS_Y_FRUTAS
  GRANOS_Y_SECOS
  BEBIDAS
  LIMPIEZA_Y_DESECHABLES
  OTRO
}

enum CategoriaGasto {
  ARRIENDO
  SERVICIOS_PUBLICOS
  NOMINA
  IMPUESTOS_Y_TASAS
  MANTENIMIENTO
  PUBLICIDAD
  CONTABILIDAD
  SEGURO
  TECNOLOGIA
  TRANSPORTE
  OTRO
}

enum PeriodicidadGasto {
  DIARIO
  SEMANAL
  QUINCENAL
  MENSUAL
  BIMESTRAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
  UNICO
}

enum MetodoPagoGasto {
  EFECTIVO
  TRANSFERENCIA
  TARJETA_DEBITO
  TARJETA_CREDITO
  CHEQUE
  OTRO
}

enum RolEmpleado {
  ADMINISTRADOR
  COCINERO
  AUXILIAR_COCINA
  MESERO
  CAJERO
  DOMICILIARIO
  ASEADOR
  OTRO
}

enum TipoContrato {
  TERMINO_FIJO
  TERMINO_INDEFINIDO
  PRESTACION_DE_SERVICIOS
  APRENDIZAJE
  OBRA_LABOR
  INFORMAL
}

enum TipoPlato {
  PLATO
  COMBO
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  restaurantName String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proveedores   Proveedor[]
  insumos       Insumo[]
  platos        Plato[]
  recetas       Receta[]
  categorias    Categoria[]
  compras         Compra[]
  compraDetalles  CompraDetalle[]
  inventarios     Inventario[]
  ventas        Venta[]
  detallesVenta DetalleVenta[]
  empleados     Empleado[]
  nominas       Nomina[]
  gastosFijos   GastoFijo[]
  comboItems    ComboItem[]
}

model Proveedor {
  id         String               @id @default(cuid())
  userId     String
  nombre     String
  telefono   String?
  categorias CategoriaProveedor[] @default([])
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  deletedAt  DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  compras Compra[]

  @@index([userId, deletedAt])
}

model Insumo {
  id                  String                @id @default(cuid())
  userId              String
  nombre              String
  unidadBase          Unidad
  categoria           CategoriaProveedor?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  deletedAt           DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  recetas          Receta[]
  compraDetalles   CompraDetalle[]
  inventarios      Inventario[]

  @@index([userId, deletedAt])
}

model Categoria {
  id        String   @id @default(cuid())
  nombre    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  platos    Plato[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([userId, deletedAt])
}

model Plato {
  id            String    @id @default(cuid())
  userId        String
  nombre        String
  categoriaId   String?
  precioVenta   Decimal   @db.Decimal(10, 2)
  active        Boolean   @default(true)
  tieneReceta   Boolean   @default(true)
  tipo          TipoPlato @default(PLATO)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoria     Categoria?     @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  recetas       Receta[]
  detallesVenta DetalleVenta[]
  itemsCombo    ComboItem[]    @relation("ComboItems")
  usadoEnCombos ComboItem[]    @relation("ComboComponente")

  @@index([userId, deletedAt])
}

model Receta {
  id        String   @id @default(cuid())
  userId    String
  platoId   String
  insumoId  String
  cantidad  Decimal  @db.Decimal(12, 4)
  unidad    Unidad
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plato  Plato  @relation(fields: [platoId], references: [id], onDelete: Cascade)
  insumo Insumo @relation(fields: [insumoId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platoId])
  @@index([insumoId])
  @@unique([platoId, insumoId])
}

model ComboItem {
  id       String @id @default(cuid())
  userId   String
  comboId  String
  platoId  String
  cantidad Int    @default(1)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  combo Plato @relation("ComboItems", fields: [comboId], references: [id], onDelete: Cascade)
  plato Plato @relation("ComboComponente", fields: [platoId], references: [id], onDelete: Restrict)

  @@unique([comboId, platoId])
  @@index([comboId])
  @@index([platoId])
  @@index([userId])
}

model Compra {
  id          String   @id @default(cuid())
  userId      String
  fecha       DateTime
  proveedorId String
  total       Decimal  @db.Decimal(10, 2)
  notas       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  proveedor Proveedor       @relation(fields: [proveedorId], references: [id])
  detalles  CompraDetalle[]

  @@index([userId])
  @@index([proveedorId])
}

model CompraDetalle {
  id             String   @id @default(cuid())
  userId         String
  compraId       String
  insumoId       String
  cantidad       Decimal  @db.Decimal(12, 4)
  unidad         Unidad
  precioUnitario Decimal  @db.Decimal(10, 2)
  total          Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  compra Compra @relation(fields: [compraId], references: [id], onDelete: Cascade)
  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@index([userId])
  @@index([compraId])
  @@index([insumoId])
}

model Inventario {
  id        String   @id @default(cuid())
  userId    String
  insumoId  String
  fecha     DateTime
  stockReal Decimal  @db.Decimal(12, 4)
  notas     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@index([userId])
  @@index([insumoId])
  @@index([userId, insumoId, fecha])
}

model Venta {
  id         String   @id @default(cuid())
  userId     String
  fecha      DateTime
  hora       String
  tipo       String
  total      Decimal  @db.Decimal(10, 2)
  metodoPago String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  detalles DetalleVenta[]

  @@index([userId])
}

model DetalleVenta {
  id             String   @id @default(cuid())
  userId         String
  ventaId        String
  platoId        String
  cantidad       Int
  precioUnitario Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venta Venta @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  plato Plato @relation(fields: [platoId], references: [id])

  @@index([userId])
  @@index([ventaId])
  @@index([platoId])
}

model Empleado {
  id           String       @id @default(cuid())
  userId       String
  nombre       String
  rol          RolEmpleado
  tipoContrato TipoContrato
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nominas Nomina[]

  @@index([userId, deletedAt])
}

model Nomina {
  id                     String   @id @default(cuid())
  userId                 String
  empleadoId             String
  periodo                DateTime

  salarioBase            Decimal  @db.Decimal(12, 2)
  auxilioTransporte      Decimal  @db.Decimal(12, 2) @default(0)
  horasExtra             Decimal  @db.Decimal(12, 2) @default(0)
  otrosIngresos          Decimal  @db.Decimal(12, 2) @default(0)

  deduccionSalud         Decimal  @db.Decimal(12, 2) @default(0)
  deduccionPension       Decimal  @db.Decimal(12, 2) @default(0)
  otrasDeduciones        Decimal  @db.Decimal(12, 2) @default(0)

  aportesSeguridadSocial Decimal  @db.Decimal(12, 2) @default(0)
  aporteParafiscales     Decimal  @db.Decimal(12, 2) @default(0)
  provisionPrestaciones  Decimal  @db.Decimal(12, 2) @default(0)

  netoEmpleado           Decimal  @db.Decimal(12, 2)
  costoTotalEmpleador    Decimal  @db.Decimal(12, 2)

  notas                  String?

  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  empleado               Empleado @relation(fields: [empleadoId], references: [id])

  @@index([userId])
  @@index([empleadoId])
  @@index([userId, periodo])
  @@unique([empleadoId, periodo])
}

model GastoFijo {
  id           String             @id @default(cuid())
  userId       String
  fecha        DateTime
  categoria    CategoriaGasto
  monto        Decimal            @db.Decimal(12, 2)
  periodicidad PeriodicidadGasto
  metodoPago   MetodoPagoGasto
  notas        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, fecha])
}
