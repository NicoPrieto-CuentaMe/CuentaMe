generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Unidad {
  GRAMO
  KILOGRAMO
  LIBRA
  MILILITRO
  LITRO
  UNIDAD
  PORCION
  CAJA
  BULTO
  GARRAFA
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  restaurantName String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proveedores  Proveedor[]
  insumos      Insumo[]
  platos       Plato[]
  recetas      Receta[]
  categorias   Categoria[]
}

model Proveedor {
  id        String   @id @default(cuid())
  userId    String
  nombre    String
  telefono  String?
  categoria String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, nombre])
}

model Insumo {
  id        String   @id @default(cuid())
  userId    String
  nombre     String
  unidadBase Unidad
  categoria  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  recetas Receta[]

  @@index([userId])
  @@unique([userId, nombre])
}

model Categoria {
  id        String   @id @default(cuid())
  nombre    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  platos    Plato[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, nombre])
}

model Plato {
  id        String   @id @default(cuid())
  userId    String
  nombre     String
  categoriaId  String?
  precioVenta Decimal @db.Decimal(10, 2)
  active    Boolean  @default(true)
  tieneReceta Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoria    Categoria? @relation(fields: [categoriaId], references: [id])
  recetas Receta[]

  @@index([userId])
  @@unique([userId, nombre])
}

model Receta {
  id        String   @id @default(cuid())
  userId    String
  platoId   String
  insumoId  String
  cantidad  Decimal  @db.Decimal(12, 4)
  unidad    Unidad
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plato  Plato  @relation(fields: [platoId], references: [id], onDelete: Cascade)
  insumo Insumo @relation(fields: [insumoId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platoId])
  @@index([insumoId])
  @@unique([platoId, insumoId])
}
