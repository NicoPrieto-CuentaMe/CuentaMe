# Neon (PostgreSQL) — copia la cadena desde el dashboard de Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secreto para firmar JWT (genera uno aleatorio, p. ej. openssl rand -base64 32)
AUTH_SECRET=""

# URL pública de la app (producción en Vercel)
AUTH_URL="http://localhost:3000"
ANTHROPIC_API_KEY="sk-ant-..."

# Neon (PostgreSQL) — URL directa para migraciones (sin pooler)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Upstash Redis — rate limiting para login y chat
UPSTASH_REDIS_REST_URL="https://your-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"