# Neon (PostgreSQL) — copia la cadena desde el dashboard de Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secreto para firmar JWT (genera uno aleatorio, p. ej. openssl rand -base64 32)
AUTH_SECRET=""

# URL pública de la app (producción en Vercel)
AUTH_URL="http://localhost:3000"
